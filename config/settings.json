{
    "project_name": "Tu Dosis Diaria - Content Factory",
    "channel_name": "Tu Dosis Diaria",
    "default_language": "es",
    "video_duration_target_minutes": 10,
    "clips_per_video": 170,
    "clip_duration_seconds": 5,
    "publication_schedule": {
        "days": ["monday", "thursday"],
        "time": "10:00",
        "timezone": "America/Mexico_City"
    },
    "models": {
        "script_generation": "claude-sonnet-4-6",
        "script_generation_fallback": "gpt-5.5",
        "emotion_tagging": "claude-sonnet-4-6",
        "emotion_tagging_fallback": "gpt-5.5",
        "video_prompts": "claude-opus-4-7",
        "video_prompts_fallback": "gpt-5.5",
        "seo_optimization": "claude-sonnet-4-6",
        "seo_optimization_fallback": "gpt-5.5",
        "openai_fallback": "gpt-5.5",
        "tts_engine": "elevenlabs",
        "image_generation": "flux1-krea-dev",
        "motion_generation": "luma-ray-flash-2",
        "subtitles": "whisper-1",
        "thumbnail_generation": "gpt-image-1.5"
    },
    "tts_config": {
        "voice_name": "Kore",
        "language": "Spanish",
        "accent": "neutral Latin American",
        "max_chars_per_chunk": 4500
    },
    "comfyui": {
        "base_url": "",
        "batch_size": 10,
        "batch_delay_seconds": 30,
        "max_retries": 3,
        "retry_delays": [10, 30, 60]
    },
    "ffmpeg": {
        "resolution": "1920x1080",
        "fps": 24,
        "codec": "libx264",
        "audio_codec": "aac",
        "transition_type": "xfade",
        "transition_duration": 0.5
    },
    "output_dirs": {
        "scripts": "output/scripts",
        "audio": "output/audio",
        "clips": "output/clips",
        "final": "output/final"
    }
}
